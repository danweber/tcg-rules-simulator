{
  "compilerOptions": {
      "target": "es2018",    
      "lib": [ "es2021.String" ],                    
      "module": "commonjs",                              
      "allowJs": true,
      "rootDir": "./",
      "esModuleInterop": true,          
      "forceConsistentCasingInFileNames": true,
      "strict": true,
      "skipLibCheck": true,                 
  },

  "include": ["**/*", "*"]
}
